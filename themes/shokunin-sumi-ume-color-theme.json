  "tokenColors": [
    {
      "name": "Comment — sumi quiet",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#777269",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings — tea green",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#157A5B"
      }
    },
    {
      "name": "Numbers and constants — kintsugi amber",
      "scope": [
        "constant.numeric",
        "variable.other.constant",
        "support.constant",
        "constant.other",
        "constant.language.boolean",
        "constant.language.json",
        "constant.language.yaml"
      ],
      "settings": {
        "foreground": "#9A6000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Python None — sumi keyword-like",
      "scope": [
        "constant.language.python"
      ],
      "settings": {
        "foreground": "#3A3E44",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keywords and control flow — sumi",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.word",
        "keyword.other",
        "storage.type.function.python",
        "storage.type.class.python",
        "storage.modifier.async.python",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#3A3E44",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators and punctuation — neutral ink",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.section",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#5C6268"
      }
    },
    {
      "name": "Types and type hints — ume",
      "scope": [
        "support.type",
        "support.type.python",
        "support.class.builtin.python",
        "entity.name.type",
        "entity.other.inherited-class",
        "meta.function.typehint.python",
        "meta.type.annotation.python",
        "meta.annotation.python",
        "storage.type.annotation.python"
      ],
      "settings": {
        "foreground": "#8F4155",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes — sumi",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class",
        "meta.class.python entity.name.type.class",
        "meta.class.python entity.name.class"
      ],
      "settings": {
        "foreground": "#3A3E44",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions and methods — asagi blue",
      "scope": [
        "entity.name.function",
        "entity.name.function.member",
        "support.function",
        "support.function.builtin",
        "variable.function"
      ],
      "settings": {
        "foreground": "#006FAE",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators — dry wood",
      "scope": [
        "entity.name.function.decorator",
        "meta.function.decorator.python",
        "punctuation.definition.decorator.python",
        "keyword.operator.decorator.python"
      ],
      "settings": {
        "foreground": "#8A4A1C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Properties and attributes — quiet structure",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.member.access",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#4E5962"
      }
    },
    {
      "name": "Parameters — main ink",
      "scope": [
        "variable.parameter",
        "meta.function.parameters variable.parameter"
      ],
      "settings": {
        "foreground": "#303841"
      }
    },
    {
      "name": "Markup headings — sumi",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#3A3E44",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup links — asagi",
      "scope": [
        "string.other.link",
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#006FAE"
      }
    },
    {
      "name": "Markup inline code — kintsugi",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#9A6000"
      }
    },
    {
      "name": "Invalid — diagnostic red only",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#C84053",
        "fontStyle": "bold"
      }
    }
  ],
